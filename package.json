{
	"name": "cartolafc-assistant",
	"private": true,
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@11.3.0",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:unsafe": "biome check --write --unsafe .",
		"lint:staged": "biome check --staged --write --no-errors-on-unmatched",
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/react": "^5.0.5",
		"@fontsource-variable/inter": "^5.2.8",
		"@tailwindcss/vite": "^4.3.0",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"astro": "^6.3.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.16.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"shadcn": "^4.8.1",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"husky": "^9.1.7",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	}
}
