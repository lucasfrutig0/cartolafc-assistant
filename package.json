{
	"name": "cartolafc-assistant",
	"private": true,
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:unsafe": "biome check --write --unsafe .",
		"lint:staged": "biome check --staged --write",
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/react": "^5.0.5",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"astro": "^6.3.8",
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"husky": "^9.1.7",
		"typescript": "^6.0.3"
	}
}
